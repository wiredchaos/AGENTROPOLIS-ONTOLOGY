{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.dev/schemas/value.schema.json",
  "title": "Value",
  "description": "Value object representing economic, civic, social, knowledge, or trust value.",
  "type": "object",
  "required": ["id", "value_type", "source_ref"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-_]*$" },
    "value_type": {
      "type": "string",
      "enum": ["revenue", "goods", "services", "knowledge", "signal", "civic", "trust", "coordination"]
    },
    "source_ref": { "type": "string" },
    "recipient_ref": { "type": "string" },
    "amount": { "type": "number" },
    "unit": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "audit_ref": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object" }
  }
}
