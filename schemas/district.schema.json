{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentropolis-ontology/schemas/district.schema.json",
  "title": "District",
  "description": "A governance and operational boundary within an Agentropolis ecosystem.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "purpose",
    "stewards",
    "policyRefs",
    "workflowRefs",
    "eventChannels",
    "security"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100
    },
    "purpose": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000
    },
    "description": {
      "type": "string",
      "maxLength": 4000
    },
    "stewards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 100
      }
    },
    "agentRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "skillRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "policyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "workflowRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "registryRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "auditRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "eventChannels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 100
      },
      "uniqueItems": true
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataClassification",
        "requiresHumanApproval",
        "logRetentionDays"
      ],
      "properties": {
        "dataClassification": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "restricted"
          ]
        },
        "requiresHumanApproval": {
          "type": "boolean"
        },
        "logRetentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650
        }
      }
    },
    "extensions": {
      "type": "object"
    }
  }
}
