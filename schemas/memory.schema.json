{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentropolis-ontology/schemas/memory.schema.json",
  "title": "Memory",
  "description": "A retained knowledge record with lifecycle and sensitivity controls.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "retention",
    "sensitivity",
    "storage",
    "accessPolicyRefs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "episodic",
        "semantic",
        "working",
        "audit"
      ]
    },
    "description": {
      "type": "string",
      "maxLength": 4000
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "days"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "ttl",
            "manual",
            "immutable"
          ]
        },
        "days": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3650
        }
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "restricted"
      ]
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locationType",
        "encrypted"
      ],
      "properties": {
        "locationType": {
          "type": "string",
          "enum": [
            "in-process",
            "external-store",
            "append-only-log"
          ]
        },
        "encrypted": {
          "type": "boolean"
        },
        "reference": {
          "type": "string",
          "maxLength": 2048
        }
      }
    },
    "accessPolicyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extensions": {
      "type": "object"
    }
  }
}
