{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentropolis-ontology/schemas/agent.schema.json",
  "title": "Agent",
  "description": "An autonomous or semi-autonomous actor operating within a district.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "districtRef",
    "role",
    "status",
    "skillRefs",
    "memoryRef",
    "policyRefs",
    "permissions",
    "security"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100
    },
    "districtRef": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 4000
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "paused",
        "retired"
      ]
    },
    "skillRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "memoryRef": {
      "type": "string"
    },
    "policyRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "workflowRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect",
        "scopes"
      ],
      "properties": {
        "effect": {
          "type": "string",
          "enum": [
            "least-privilege",
            "constrained",
            "elevated"
          ]
        },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100
          },
          "uniqueItems": true
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handlesSensitiveData",
        "requiresHumanApproval",
        "eventChannel"
      ],
      "properties": {
        "handlesSensitiveData": {
          "type": "boolean"
        },
        "requiresHumanApproval": {
          "type": "boolean"
        },
        "eventChannel": {
          "type": "string",
          "minLength": 3,
          "maxLength": 100
        }
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 100
      },
      "uniqueItems": true
    },
    "extensions": {
      "type": "object"
    }
  }
}
