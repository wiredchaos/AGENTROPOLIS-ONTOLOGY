{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentropolis-ontology/schemas/policy.schema.json",
  "title": "Policy",
  "description": "A governance rule or control statement that can be enforced by implementations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "category",
    "statements",
    "enforcement"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 150
    },
    "category": {
      "type": "string",
      "enum": [
        "security",
        "privacy",
        "safety",
        "compliance",
        "operations"
      ]
    },
    "description": {
      "type": "string",
      "maxLength": 4000
    },
    "statements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 1000
      }
    },
    "enforcement": {
      "type": "string",
      "enum": [
        "advisory",
        "preventive",
        "detective",
        "corrective"
      ]
    },
    "appliesTo": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "district",
          "agent",
          "skill",
          "memory",
          "workflow",
          "event"
        ]
      },
      "uniqueItems": true
    },
    "extensions": {
      "type": "object"
    }
  }
}
